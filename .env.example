# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://user:password@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/?authSource=admin&replicaSet=atlas-xxxxx-shard-0&tls=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRE=7d

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqps://user:password@gull.rmq.cloudamqp.com/vhost
RABBITMQ_EXCHANGE=emergency_platform

# ─── Service ports (local dev only — Render injects PORT automatically) ───────
AUTH_SERVICE_PORT=3001
INCIDENT_SERVICE_PORT=3002
DISPATCH_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004

# ─── Inter-service URL ────────────────────────────────────────────────────────
DISPATCH_SERVICE_URL=http://localhost:3003
